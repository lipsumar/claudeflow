    "@types/lodash": "^4",
    "@types/node": "^22",
    "tsdown": "^0.21.2",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "citty": "^0.2.1",
    "dockerode": "^4.0.10",
    "jiti": "^2.6.1",
    "lodash": "^4.17.23",
    "ora": "^9.3.0",
    "zod": "^4.3.6"
  }
