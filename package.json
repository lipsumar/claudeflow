{
  "name": "@lipsumar/claudeflow",
  "version": "0.0.1",
  "packageManager": "yarn@4.13.0",
  "type": "module",
  "files": [
    "dist"
  ],
  "bin": "./dist/cli/index.mjs",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    }
  },
  "scripts": {
